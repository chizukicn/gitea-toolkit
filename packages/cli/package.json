{
  "name": "@gitea-toolkit/cli",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/chizukicn/gitea-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chizukicn/gitea-toolkit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/chizukicn/gitea-toolkit/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.mjs",
  "types": "./dist/cli.d.cts",
  "bin": {
    "tea": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "run": "tsx src/cli.ts",
    "lint": "eslint --cache -f mo src",
    "test": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gitea-toolkit/core": "workspace:*",
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsdown": "0.22.1",
    "typescript": "6.0.3"
  }
}
