{
  "name": "@gitea-toolkit/mcp",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/chizukicn/gitea-toolkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chizukicn/gitea-toolkit.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/chizukicn/gitea-toolkit/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/mcp.mjs",
      "require": "./dist/mcp.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/mcp.cjs",
  "module": "./dist/mcp.mjs",
  "types": "./dist/mcp.d.cts",
  "bin": {
    "gitea-mcp": "./dist/mcp.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint --cache -f mo src",
    "test": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gitea-toolkit/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3"
  }
}
