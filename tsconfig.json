{
  "compilerOptions": {
    "target": "esnext",
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "paths": {
      "@gitea-toolkit/core": ["packages/core/src"],
      "@gitea-toolkit/cli": ["packages/cli/src"],
      "@gitea-toolkit/mcp": ["packages/mcp/src"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "include": ["packages/*/src", "packages/*/test"]
}
